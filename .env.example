# Example .env for relatorioMarcacaoKairosAPI
# Copy this file to .env and fill in real values

# SQL Server connection
DB_SERVER=your_sql_server_hostname_or_ip
DB_NAME=your_database_name
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_DRIVER={ODBC Driver 17 for SQL Server}

# Flask secret key
SECRET_KEY=change_this_to_a_random_secret

# Kairos API (optional)
KAIROS_KEY=your_kairos_api_key
KAIROS_IDENTIFIER=your_kairos_identifier

# Optional: development mode
FLASK_ENV=development

# Timezone configuration
# Default timezone for PDF date/time stamps (standard IANA timezone names)
APP_TIMEZONE=America/Sao_Paulo
# Fallback timezone offset in hours (used if timezone database is unavailable on system)
TIMEZONE_OFFSET=-3

